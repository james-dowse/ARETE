generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Movement {
  id               String             @id
  name             String
  bioType          String
  complexity       String
  equipment        String?
  description      String?
  imageUrl         String?
  videoUrl         String?
  workoutMovements WorkoutMovement[]
  favorites        FavoriteMovement[]
}

model Workout {
  id          String            @id @default(cuid())
  name        String
  createdAt   DateTime          @default(now())
  duration    Int?
  notes       String?
  description String?
  imageUrl    String?
  templateId  String?
  userId      String?
  blockRest   Int?
  tags        String?
  movements   WorkoutMovement[]
  blocks      WorkoutBlock[]
  shares      WorkoutShare[]
  savedBy     SavedWorkout[]
  favoritedBy FavoriteWorkout[]
  planEntries WeekPlanEntry[]
  sessions    WorkoutSession[]
  template    WorkoutTemplate?  @relation(fields: [templateId], references: [id])
  user        InvitedUser?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WorkoutBlock {
  id           String            @id @default(cuid())
  workoutId    String
  order        Int
  bioType      String?
  instructions String?
  restAfter    Int?
  workout      Workout           @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  movements    WorkoutMovement[]
}

model WorkoutMovement {
  id         String        @id @default(cuid())
  workoutId  String
  movementId String
  order      Int
  sets       Int?
  reps       String?
  rest       Int?
  duration   Int?
  blockId    String?
  movement   Movement      @relation(fields: [movementId], references: [id])
  workout    Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  block      WorkoutBlock? @relation(fields: [blockId], references: [id])
}

model WorkoutTemplate {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  userId    String?
  blocks    TemplateBlock[]
  workouts  Workout[]
  user      InvitedUser?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model TemplateBlock {
  id         String          @id @default(cuid())
  templateId String
  bioType    String?
  complexity String?
  equipments String?
  count      Int
  order      Int
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model InvitedUser {
  id             String            @id @default(cuid())
  email          String            @unique
  token          String            @unique @default(cuid())
  status         String            @default("pending")
  invitedAt      DateTime          @default(now())
  acceptedAt     DateTime?
  firstName      String?
  lastName       String?
  bio            String?
  avatarUrl      String?
  workouts       Workout[]
  templates      WorkoutTemplate[]
  sharesSent     WorkoutShare[]    @relation("SharesSent")
  sharesReceived WorkoutShare[]    @relation("SharesReceived")
  savedWorkouts    SavedWorkout[]
  favorites        FavoriteMovement[]
  favoriteWorkouts FavoriteWorkout[]
  weekPlans        WeekPlan[]
  workoutSessions  WorkoutSession[]
}

model WeekPlan {
  id        String         @id @default(cuid())
  userId    String
  weekStart DateTime
  user      InvitedUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   WeekPlanEntry[]

  @@unique([userId, weekStart])
}

model WeekPlanEntry {
  id         String    @id @default(cuid())
  weekPlanId String
  workoutId  String
  dayOfWeek  Int       // 0=Lun … 6=Dim
  order      Int       @default(0)
  weekPlan   WeekPlan  @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  workout    Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model FavoriteMovement {
  id         String      @id @default(cuid())
  userId     String
  movementId String
  createdAt  DateTime    @default(now())
  user       InvitedUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  movement   Movement    @relation(fields: [movementId], references: [id], onDelete: Cascade)

  @@unique([userId, movementId])
}

model SavedWorkout {
  id           String      @id @default(cuid())
  workoutId    String
  workout      Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  userId       String
  user         InvitedUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAt      DateTime    @default(now())
  source       String      @default("manual") // "manual" | "shared"
  lastViewedAt DateTime?

  @@unique([workoutId, userId])
}

model WorkoutSession {
  id        String      @id @default(cuid())
  userId    String
  workoutId String
  doneAt    DateTime    @default(now())
  note      String?
  user      InvitedUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model FavoriteWorkout {
  id        String      @id @default(cuid())
  userId    String
  workoutId String
  createdAt DateTime    @default(now())
  user      InvitedUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@unique([userId, workoutId])
}

model AttributeOption {
  id       String @id @default(cuid())
  category String // 'bioType' | 'complexity' | 'equipment'
  value    String
  icon     String?
  color    String?
  position Int    @default(0)

  @@unique([category, value])
}

model WorkoutShare {
  id             String       @id @default(cuid())
  workoutId      String
  workout        Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sharedByUserId String
  sharedByUser   InvitedUser  @relation("SharesSent", fields: [sharedByUserId], references: [id])
  sharedToEmail  String
  sharedToUserId String?
  sharedToUser   InvitedUser? @relation("SharesReceived", fields: [sharedToUserId], references: [id])
  token          String       @unique @default(cuid())
  status         String       @default("pending")
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?
}
